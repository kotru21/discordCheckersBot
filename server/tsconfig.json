{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "noEmit": true,
    "paths": {
      "@shared/*": ["../activity/src/shared/*"]
    }
  },
  "include": ["src/**/*"]
}
