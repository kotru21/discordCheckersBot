{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "noEmit": true,
    "paths": {
      "@discord-checkers/game": ["../packages/game/src/index.ts"],
      "@discord-checkers/game/*": ["../packages/game/src/*"]
    }
  },
  "include": ["src/**/*"]
}
